AddKeysToAgent yes
SetEnv TERM=xterm-256color

Host github.com
    Hostname ssh.github.com
    User git
    IdentityFile ~/.ssh/github
    ForwardX11 no

Host gist.github.com
    Hostname gist.github.com
    User git
    Port 443
    IdentityFile ~/.ssh/github
    ForwardX11 no

Host vps
    User ubuntu
    Hostname cultab.xyz
    IdentityFile ~/.ssh/ovh_cloud

